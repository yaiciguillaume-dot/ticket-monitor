# ─── Serveur ─────────────────────────────────────────────
PORT=3000
# Intervalle de vérification par défaut (secondes). Min recommandé : 20s.
DEFAULT_INTERVAL=60

# ─── Telegram ────────────────────────────────────────────
# 1. Sur Telegram, parle à @BotFather → /newbot → récupère le token
# 2. Envoie un message à ton bot, puis ouvre
#    https://api.telegram.org/bot<TOKEN>/getUpdates pour lire ton chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Email (SMTP) ────────────────────────────────────────
# Exemple Gmail : host=smtp.gmail.com port=587, et un "mot de passe d'application"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
